{
  "name": "mealmind",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,green \"npm run dev -w @mealmind/api\" \"npm run dev -w @mealmind/web\"",
    "dev:web": "npm run dev -w @mealmind/web",
    "dev:api": "npm run dev -w @mealmind/api",
    "build": "npm run build -w @mealmind/contracts && npm run build -w @mealmind/domain && npm run build -w @mealmind/db && npm run build -w @mealmind/ai && npm run build -w @mealmind/api && npm run build -w @mealmind/mcp && npm run build -w @mealmind/ai-gateway && npm run build -w @mealmind/web",
    "start": "npm run start -w @mealmind/web",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "mcp": "npm run mcp -w @mealmind/mcp",
    "mcp:smoke": "tsx tests/mcp/smoke.ts",
    "mcp:http-smoke": "tsx tests/mcp/http-smoke.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "npm run db:migrate -w @mealmind/db",
    "db:migrate:sqlite": "tsx scripts/migrate-sqlite-to-postgres.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.6.2",
    "glob": "^13.0.6",
    "lucide-react": "^1.21.0",
    "next": "^16.2.9",
    "openai": "^6.44.0",
    "pg": "^8.16.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.0.0",
    "@types/pg": "^8.15.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.23",
    "better-sqlite3": "^12.11.1",
    "drizzle-kit": "^0.31.10",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
